	pages = {61},
	file = {Full Text PDF:/Users/leonackermann/Zotero/storage/C5RRA2NI/Torous et al. - 2015 - Realizing the Potential of Mobile Mental Health New Methods for New Data in Psychiatry.pdf:application/pdf},
}

@book{seriesComputationalPsychiatryPrimer2020,
	address = {Cambridge},
	title = {Computational psychiatry: a primer},
	isbn = {978-0-262-04459-2},
	shorttitle = {Computational psychiatry},
	abstract = {"Computational psychiatry represents a novel and multidisciplinary approach to mental dysfunction. Computational psychiatry seeks to characterize mental dysfunction in terms of deviations from healthy brain computations over multiple time scales. It focuses on building mathematical models of neural or cognitive phenomena relevant to psychiatric diseases. One critical function of these models is their ability to bridge between low-level biological (neuroscience) and high-level cognitive features (psychiatric symptoms). This is the first textbook in the new field of computational psychiatry, designed for the next generation of scientists and clinicians who wish to apply computational models to modern diagnosis and treatment strategies"},
	language = {en},
	publisher = {MIT press},
	author = {Seriès, Peggy},
	year = {2020},
