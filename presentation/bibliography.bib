	keywords = {Goodness-of-fit, Information Matrix Test, model misspecification, model selection, specification analysis},
	pages = {105--139},
	file = {Full Text PDF:/Users/leonackermann/Zotero/storage/NT6F2ZS7/Henley et al. - 2020 - Statistical modeling methods challenges and strategies.pdf:application/pdf},
}

